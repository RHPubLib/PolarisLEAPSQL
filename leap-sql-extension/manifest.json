{
  "manifest_version": 3,
  "name": "LEAP SQL Helper",
  "version": "1.5.5",
  "description": "Ask the Polaris SQL Helper directly from LEAP — no tab switching needed.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://your-openwebui-server/*",
    "https://yourlibrary.polarislibrary.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "storage": {
    "managed_schema": "schema.json"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
